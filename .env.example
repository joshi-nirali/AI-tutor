# bitHuman Essence Cloud — kid tutor (agent.py + token_server + React)
# Copy: cp .env.example .env

# ── bitHuman (required for avatar video) ─────────────────────
BITHUMAN_API_SECRET=your_api_secret_here
BITHUMAN_AGENT_ID=your_agent_id_here

# ── OpenAI (required for agent.py voice + realtime) ───────────
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_VOICE=coral

# ── LiveKit Cloud (same project for token_server + agent + browser) ──
# Dashboard: https://cloud.livekit.io → your project → Settings
#   - WebSocket URL → LIVEKIT_URL (must start with wss://)
#   - API Keys → create a key; use its Key and Secret below
# The Python worker (agent.py) and the token server must use THIS project so
# rooms and agent dispatch match what the React app joins.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxx

# Optional: token server port (default 5000)
# TOKEN_SERVER_PORT=5000

# Optional: override path to fixed word lists JSON (default: data/word_lists.json)
# KID_CURRICULUM_PATH=/path/to/custom_word_lists.json

# If the browser loads the React app from another host/port, set the public URL of
# token_server so /curriculum image URLs work (e.g. https://api.myapp.com)
# TOKEN_SERVER_PUBLIC_URL=https://your-token-host.example.com

# Fallback display name if the room name does not include a tutor slug (normally unused;
# the UI encodes leo/luna in the LiveKit room name for agent.py).
# TUTOR_NAME=Leo

# ── Legacy / other ────────────────────────────────────────────
# NODE_IP=203.0.113.1
