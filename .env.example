# bitHuman Essence Cloud — kid tutor (agent.py + token_server + React)
# Copy: cp .env.example .env

# ── bitHuman (for avatar video; optional if KID_TUTOR_USE_AVATAR=0) ──
BITHUMAN_API_SECRET=your_api_secret_here
BITHUMAN_AGENT_ID=your_agent_id_here

# Voice-only dev: skip bitHuman AvatarSession (no BITHUMAN_AGENT_ID required).
# KID_TUTOR_USE_AVATAR=0
# Alias if KID_TUTOR_USE_AVATAR is unset: USE_BITUMAN_AVATAR=0

# ── OpenAI (required for agent.py voice + realtime) ───────────
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_VOICE=coral
# Realtime speech model (must be enabled for your OpenAI key). Default is GA name gpt-realtime.
# If you see model_not_found in agent logs, set one your account supports, e.g.:
# OPENAI_REALTIME_MODEL=gpt-realtime-1.5

# ── LiveKit Cloud (same project for token_server + agent + browser) ──
# Dashboard: https://cloud.livekit.io → your project → Settings
#   - WebSocket URL → LIVEKIT_URL (must start with wss://)
#   - API Keys → create a key; use its Key and Secret below
# The Python worker (agent.py) and the token server must use THIS project so
# rooms and agent dispatch match what the React app joins.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxx

# Optional: Python worker WebRTC ICE mode. If agent logs show "Publisher pc state failed" or
# "publisher connection: timeout" / stream_bytes errors, try forcing TURN:
# LIVEKIT_AGENT_ICE_TRANSPORT=relay
# Other values: nohost, all (default when unset)

# Optional: agent mic pipeline — KID_TUTOR_PRE_CONNECT_AUDIO=0 slightly speeds session start (may clip first sound).
# KID_TUTOR_AGENT_NOISE_FILTER=1 enables LiveKit BVC on the agent (requires: pip install livekit-plugins-noise-cancellation).
# KID_TUTOR_PRE_CONNECT_AUDIO=0
KID_TUTOR_AGENT_NOISE_FILTER=1

# Optional: token server port (default 5000)
# TOKEN_SERVER_PORT=5000

# Optional: override path to fixed word lists JSON (default: data/word_lists.json)
# KID_CURRICULUM_PATH=/path/to/custom_word_lists.json

# Optional: directory with ai_prompts.json, response_templates.json, pronunciation_rules.json
# (default: data/prompts/)
# KID_PROMPTS_DIR=/path/to/prompts

# After each scored pronunciation, interrupt in-flight speech and run one guided generate_reply (default on).
# Set to 0 to only refresh instructions + data channel (less aggressive).
# KID_TUTOR_SCORING_REPLY=0

# Max seconds to wait for session.interrupt() during that flow (default 0.85, clamped 0.15–8).
# KID_TUTOR_INTERRUPT_TIMEOUT=1.2

# After a "correct" pronunciation score, auto-advance lesson picture one step (default off).
# KID_TUTOR_AUTO_ADVANCE_ON_CORRECT=1

# If the browser loads the React app from another host/port, set the public URL of
# token_server so /curriculum image URLs work (e.g. https://api.myapp.com)
# TOKEN_SERVER_PUBLIC_URL=https://your-token-host.example.com

# Fallback display name if the room name does not include a tutor slug (normally unused;
# the UI encodes leo/luna in the LiveKit room name for agent.py).
# TUTOR_NAME=Leo

# ── Legacy / other ────────────────────────────────────────────
# NODE_IP=203.0.113.1
