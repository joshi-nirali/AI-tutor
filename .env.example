# bitHuman Essence Cloud — kid tutor (agent.py + token_server + React)
# Copy: cp .env.example .env

# ── bitHuman (for avatar video; optional if KID_TUTOR_USE_AVATAR=0) ──
BITHUMAN_API_SECRET=your_api_secret_here

# One BitHuman agent ID per tutor character (create each agent at https://www.bithuman.ai).
# Slug comes from the picker in frontend/src/App.js (`AVATARS[].id`, e.g. leo, luna) and appears in
# the LiveKit room name: kidtutor-{mode}-{topic}-{slug}-{session}.
# Env key is BITHUMAN_AGENT_ID_<SLUG_UPPERCASE> — e.g. leo → BITHUMAN_AGENT_ID_LEO.
BITHUMAN_AGENT_ID_LEO=your_leo_agent_id_here
BITHUMAN_AGENT_ID_LUNA=your_luna_agent_id_here
# Optional extra picker / tutor slug:
# BITHUMAN_AGENT_ID_CUB=your_cub_agent_id_here
# If a slug has no line above, agent.py falls back to:
BITHUMAN_AGENT_ID=your_fallback_agent_id_here

# Voice-only dev: skip bitHuman AvatarSession (no BITHUMAN_AGENT_ID required).
# KID_TUTOR_USE_AVATAR=0
# Alias if KID_TUTOR_USE_AVATAR is unset: USE_BITUMAN_AVATAR=0

# ── OpenAI (required for agent.py voice + realtime) ───────────
OPENAI_API_KEY=sk-your_openai_key_here

# Default OpenAI Realtime voice (used as a fallback only).
# Per-tutor voices are configured in agent.py -> TUTOR_FROM_SLUG (e.g. Leo=ballad, Luna=shimmer).
# Voice precedence at runtime:
#   1. OPENAI_VOICE_<SLUG>           (per-tutor env override, e.g. OPENAI_VOICE_LEO=ballad)
#   2. TUTOR_FROM_SLUG[slug].voice   (curated default in code)
#   3. OPENAI_VOICE                  (this global fallback)
#   4. "coral"                       (hardcoded)
OPENAI_VOICE=coral
# Examples — uncomment to override a tutor's voice without touching code:
OPENAI_VOICE_LEO=ballad
OPENAI_VOICE_LUNA=shimmer
OPENAI_VOICE_CUB=sage

# Realtime speech model (must be enabled for your OpenAI key). Default is GA name gpt-realtime.
# If you see model_not_found in agent logs, set one your account supports, e.g.:
# OPENAI_REALTIME_MODEL=gpt-realtime-1.5

# ── LiveKit Cloud (same project for token_server + agent + browser) ──
# Dashboard: https://cloud.livekit.io → your project → Settings
#   - WebSocket URL → LIVEKIT_URL (must start with wss://)
#   - API Keys → create a key; use its Key and Secret below
# The Python worker (agent.py) and the token server must use THIS project so
# rooms and agent dispatch match what the React app joins.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxx

# Optional: Python worker WebRTC ICE mode. If agent logs show "Publisher pc state failed" or
# "publisher connection: timeout" / stream_bytes errors, try forcing TURN:
# LIVEKIT_AGENT_ICE_TRANSPORT=relay
# Other values: nohost, all (default when unset)

# Optional: agent mic pipeline — KID_TUTOR_PRE_CONNECT_AUDIO=0 slightly speeds session start (may clip first sound).
# KID_TUTOR_AGENT_NOISE_FILTER=1 enables LiveKit BVC on the agent (requires: pip install livekit-plugins-noise-cancellation).
# KID_TUTOR_PRE_CONNECT_AUDIO=0
KID_TUTOR_AGENT_NOISE_FILTER=1

# Optional: token server port (default 5000)
# TOKEN_SERVER_PORT=5000

# Optional: override path to fixed word lists JSON (default: data/word_lists.json)
# KID_CURRICULUM_PATH=/path/to/custom_word_lists.json

# Optional: directory with ai_prompts.json, response_templates.json, pronunciation_rules.json
# (default: data/prompts/)
# KID_PROMPTS_DIR=/path/to/prompts

# After a scored pronunciation, interrupt in-flight speech and run one guided generate_reply.
# Default ON, but only fires for moments that REQUIRE redirecting the agent's voice:
#   - "correct" + auto-advance (cut over to the next word)
#   - last word completed (wrap-up)
#   - retries exceeded (gentle skip)
# For "almost"/"incorrect" still-trying turns, the OpenAI Realtime model's natural
# turn-taking responds — this avoids thrashing the bitHuman avatar buffer pipeline,
# which used to cause audible cut-outs and "speech not done in time" errors.
# Set to 0 to disable scripted replies entirely (relies fully on natural turn-taking).
# KID_TUTOR_SCORING_REPLY=0

# Max seconds to wait for session.interrupt() during the scripted-reply flow.
# Default 2.0s (clamped 0.15–8). Bump higher if you still see
# "speech not done in time after interruption" / clear-buffer RPC timeouts on
# the relay path (LIVEKIT_AGENT_ICE_TRANSPORT=relay needs more headroom than direct).
# KID_TUTOR_INTERRUPT_TIMEOUT=2.5

# After a "correct" pronunciation score, auto-advance lesson picture one step (default off).
# KID_TUTOR_AUTO_ADVANCE_ON_CORRECT=1

# Seconds to ignore pronunciation scoring after (a) greeting→first-word intro or (b) each auto-advance
# celebration. Prevents bogus Realtime STT finals (noise / speaker bleed) from matching the lesson word
# and skipping ahead while the child is silent. Defaults 5.0 / 3.5 — raise slightly if false positives remain.
# KID_TUTOR_POST_INTRO_SCORING_DELAY_S=5.0
# KID_TUTOR_POST_ADVANCE_SCORING_DELAY_S=3.5
# Optional: if session_ui_ready never arrives (BitHuman), force intro after this many seconds (default 45 avatar / 8 voice-only).
# KID_TUTOR_GREETING_UI_FALLBACK_S=45

# When the LAST word of a lesson is finished correctly, the agent emits a
# `lesson_complete` data signal so the browser can auto-redirect the child back
# to the categories grid after a goodbye plays out. Tune the grace period (in
# milliseconds, clamped 2000–30000) if your goodbye reply is unusually long
# or short. Default 11000 (11 seconds) — enough for a 1–2 sentence wrap-up
# spoken by the OpenAI Realtime model + bitHuman avatar pipeline latency.
# KID_TUTOR_LESSON_COMPLETE_DELAY_MS=11000

# If the browser loads the React app from another host/port, set the public URL of
# token_server so /curriculum image URLs work (e.g. https://api.myapp.com)
# TOKEN_SERVER_PUBLIC_URL=https://your-token-host.example.com

# Fallback display name if the room name does not include a tutor slug (normally unused;
# the UI encodes leo/luna in the LiveKit room name for agent.py).
# TUTOR_NAME=Leo

# ── Legacy / other ────────────────────────────────────────────
# NODE_IP=203.0.113.1
