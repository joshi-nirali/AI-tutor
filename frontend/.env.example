# Copy to .env.local for Create React App
# Token API (must match token_server.py, default port 5000)
REACT_APP_TOKEN_SERVER_URL=http://127.0.0.1:5000/token

# Optional: if you do not return "url" from /token, set the LiveKit WebSocket URL here
# REACT_APP_LIVEKIT_URL=wss://your-project.livekit.cloud
